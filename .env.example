# App URL used by client and auth callbacks
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database
DATABASE_URL="postgres://postgres:postgres@127.0.0.1:5432/task_tracker"

# Better Auth
BETTER_AUTH_SECRET="replace-with-32-plus-char-random-secret"
BETTER_AUTH_URL="http://localhost:3000"

# Seed/bootstrap helper (optional)
# If set, `bun run db:seed` targets this user. If empty, the seed uses the earliest created user.
SEED_USER_EMAIL=""

# Reminder worker + email delivery
# `RESEND_*` can stay empty for dry-run worker mode during local development.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Momentum <no-reply@example.com>"
REMINDER_WORKER_BATCH_SIZE="100"

# S3 uploads
# Required when using attachment upload flows.
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_PUBLIC_BASE_URL=""
