{
  "name": "task-tracker-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "test": "bun test",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "verify": "bun run typecheck && bun run lint && bun run build",
    "worker:reminders": "bun run src/scripts/reminder-worker.ts",
    "worker:reminders:dry": "bun run src/scripts/reminder-worker.ts --dry-run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/server/db/seed.ts",
    "db:bootstrap": "bun run db:migrate && bun run db:seed",
    "docker:build": "docker build -t task-tracker-app .",
    "docker:run": "docker run --rm --env-file .env -p 3000:3000 task-tracker-app"
  },
  "dependencies": {
    "@t3-oss/env-nextjs": "^0.13.8",
    "@aws-sdk/client-s3": "^3.897.0",
    "@aws-sdk/s3-request-presigner": "^3.897.0",
    "@tanstack/react-query": "^5.90.5",
    "@trpc/client": "^11.7.2",
    "@trpc/react-query": "^11.7.2",
    "@trpc/server": "^11.7.2",
    "better-auth": "^1.3.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.6",
    "lucide-react": "^0.545.0",
    "next": "^15.5.3",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.7",
    "react": "^19.1.1",
    "react-markdown": "^10.1.0",
    "react-dom": "^19.1.1",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "superjson": "^2.2.2",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "bun-types": "^1.3.3",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9.35.0",
    "eslint-config-next": "^15.5.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.2"
  }
}
